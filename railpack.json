{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "dotnet restore src/Archive.Api/Archive.Api.csproj"
      ]
    },
    "build": {
      "commands": [
        "dotnet publish src/Archive.Api/Archive.Api.csproj -c Release -o out"
      ]
    }
  },
  "deploy": {
    "startCommand": "ASPNETCORE_URLS=http://0.0.0.0:${PORT:-8080} ASPNETCORE_ENVIRONMENT=Production dotnet out/Archive.Api.dll",
    "variables": {
      "ASPNETCORE_ENVIRONMENT": "Production"
    }
  }
}
